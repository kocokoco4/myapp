rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // デフォルト拒否
    match /{document=**} {
      allow read, write: if false;
    }

    // ユーザーメタ（plan, level, curId等）
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false;

      // 曲コレクション（サブコレクション）
      match /songs/{songId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSong();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // カスタム辞典（マイ進行）
      match /progressions/{progId} {
        allow read, write: if isOwner(userId);
      }

      // 使用量カウンター（日別）
      match /usage/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // お知らせ（運営から全ユーザーへ読み取り専用）
    match /announcements/{id} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK経由でのみ書き込み
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isValidSong() {
      let data = request.resource.data;
      return data.keys().hasAll(['title', 'key', 'tempo', 'createdAt', 'updatedAt'])
        && data.title is string
        && data.title.size() <= 200
        && data.tempo is number;
    }
  }
}
